# =============================================================================
# Single-Cell Intelligence Agent - Environment Configuration
# Copy this file to .env and set your values
# =============================================================================

# -- Anthropic API Key (required for LLM features) --
ANTHROPIC_API_KEY=sk-ant-your-key-here

# -- Milvus Vector Database --
SC_MILVUS_HOST=localhost
SC_MILVUS_PORT=19530

# -- Service Ports --
SC_API_PORT=8540
SC_STREAMLIT_PORT=8130

# -- Embeddings --
SC_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# -- LLM --
SC_LLM_MODEL=claude-sonnet-4-6

# -- RAG Search --
SC_SCORE_THRESHOLD=0.4

# -- Authentication (empty = no auth required) --
SC_API_KEY=

# -- CORS --
SC_CORS_ORIGINS=http://localhost:8080,http://localhost:8130,http://localhost:8540

# -- Scheduled Ingest --
SC_INGEST_ENABLED=false
SC_INGEST_SCHEDULE_HOURS=24

# -- External APIs (optional) --
SC_CELLXGENE_API_URL=
SC_NCBI_API_KEY=

# -- Prometheus Metrics --
SC_METRICS_ENABLED=true

# -- GPU Memory --
SC_GPU_MEMORY_LIMIT_GB=120

# -- Request Limits --
SC_MAX_REQUEST_SIZE_MB=10
